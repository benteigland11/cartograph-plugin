{
  "name": "cartograph",
  "version": "0.1.1",
  "description": "Widget library manager for AI agents. Search, install, validate, and publish reusable code components across languages and domains.",
  "author": {
    "name": "Ben Teigland",
    "url": "https://github.com/benteigland11/Cartograph"
  },
  "homepage": "https://github.com/benteigland11/Cartograph",
  "repository": "https://github.com/benteigland11/cartograph-plugin",
  "license": "MIT",
  "keywords": ["widgets", "code-reuse", "agents", "library", "cartograph"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/init-mcp.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "cartograph": {
      "command": "python3",
      "args": ["-m", "cartograph_mcp.server"],
      "env": {
        "PYTHONPATH": "${CLAUDE_PLUGIN_DATA}/lib"
      }
    }
  }
}
